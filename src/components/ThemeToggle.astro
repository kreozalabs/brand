---
/* ThemeToggle.astro */
import { Icon } from "@astrojs/starlight/components";
---

{/* Inlined to avoid FOUC */}
<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  type Theme = "dark" | "light";

  const storageKey = "kreoza-theme";

  /** Get system theme fallback */
  const getPreferredColorScheme = (): Theme =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  /** Load saved theme or fall back to system theme */
  const loadTheme = (): Theme => {
    if (typeof localStorage !== "undefined") {
      const saved = localStorage.getItem(storageKey);
      if (saved === "dark" || saved === "light") return saved;
    }
    return getPreferredColorScheme();
  };

  /** Store choice in localStorage */
  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== "undefined") {
      localStorage.setItem(storageKey, theme);
    }
  }

  /** Apply theme to document */
  function applyTheme(theme: Theme): void {
    document.documentElement.dataset.theme = theme;
    StarlightThemeProvider.updatePickers?.(theme);
    storeTheme(theme);
  }

  /** Toggle between dark and light with a circular View Transition */
  function toggleTheme(event?: MouseEvent): void {
    const currentTheme = loadTheme();
    const nextTheme: Theme = currentTheme === "dark" ? "light" : "dark";

    const isTransitionSupported =
      typeof document !== "undefined" &&
      "startViewTransition" in document &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!isTransitionSupported) {
      applyTheme(nextTheme);
      return;
    }

    // Get the click coordinates, or fallback to the button's center
    let x = window.innerWidth / 2;
    let y = window.innerHeight / 2;

    if (event) {
      x = event.clientX;
      y = event.clientY;
    } else {
      const button = document.querySelector("starlight-theme-toggle button");
      if (button) {
        const rect = button.getBoundingClientRect();
        x = rect.left + rect.width / 2;
        y = rect.top + rect.height / 2;
      }
    }

    // Calculate distance to farthest corner to determine maximum radius
    const endRadius = Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y),
    );

    const transition = document.startViewTransition(() => {
      applyTheme(nextTheme);
    });

    transition.ready.then(() => {
      const clipPath = [
        `circle(0px at ${x}px ${y}px)`,
        `circle(${endRadius}px at ${x}px ${y}px)`,
      ];

      document.documentElement.animate(
        {
          clipPath: clipPath,
        },
        {
          duration: 400,
          easing: "ease-in-out",
          pseudoElement: "::view-transition-new(root)",
        },
      );
    });
  }

  // React to OS dark/light mode changes if no manual choice was set
  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (
      typeof localStorage !== "undefined" &&
      !localStorage.getItem(storageKey)
    ) {
      applyTheme(getPreferredColorScheme());
    }
  });

  class StarlightThemeToggle extends HTMLElement {
    constructor() {
      super();
      // Apply initial theme on load
      applyTheme(loadTheme());

      // Toggle on button click, passing event for coordinates
      this.querySelector("button")?.addEventListener("click", (e) => {
        toggleTheme(e);
      });
    }
  }

  customElements.define("starlight-theme-toggle", StarlightThemeToggle);
</script>

<starlight-theme-toggle>
  <button
    type="button"
    aria-label="Toggle theme"
    title="Toggle dark/light mode"
  >
    <Icon name="sun" class="icon-sun" />
    <Icon name="moon" class="icon-moon" />
    <span class="sr-only">Toggle theme</span>
  </button>
</starlight-theme-toggle>

<style>
  @layer starlight.core {
    button {
      background: transparent;
      border: none;
      color: var(--sl-color-text-accent);
      padding: 0.5em;
      margin: -0.5em;
      cursor: pointer;
      font-size: inherit;
      font-family: inherit;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
    }

    button:hover {
      color: var(--sl-color-white);
    }
  }

  .icon-sun,
  .icon-moon {
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  button:hover .icon-sun,
  button:hover .icon-moon {
    transform: scale(1.12) rotate(15deg);
  }

  button:active .icon-sun,
  button:active .icon-moon {
    transform: scale(0.9) rotate(-5deg);
  }

  /* Theme display logic with entry animations */
  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) .icon-moon {
    display: block;
    animation: theme-entry 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global([data-theme="light"]) .icon-sun {
    display: block;
    animation: theme-entry 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global([data-theme="light"]) .icon-moon {
    display: none;
  }

  @keyframes theme-entry {
    from {
      transform: scale(0.5) rotate(-45deg);
      opacity: 0;
    }
  }

  /* View Transition API styles for theme toggle */
  @media (prefers-reduced-motion: no-preference) {
    :global(::view-transition-group(root)) {
      animation-duration: 400ms;
    }

    :global(::view-transition-old(root)),
    :global(::view-transition-new(root)) {
      animation: none;
      mix-blend-mode: normal;
    }

    :global(::view-transition-old(root)) {
      z-index: 1;
    }

    :global(::view-transition-new(root)) {
      z-index: 99999;
    }
  }

  /* Screen reader helper */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
